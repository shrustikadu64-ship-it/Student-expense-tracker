<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">

    <h2 class="mb-4 text-primary">
        💰 Monthly Budget
    </h2>

    <%- include('../partials/flash') %>

    <div class="card shadow mb-5">

        <div class="card-body">

            <form action="/budget" method="POST">

                <div class="mb-3">

                    <label class="form-label">
                        Month
                    </label>

                    <input
                        type="month"
                        name="month"
                        value="<%= month %>"
                        class="form-control"
                        required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Budget Amount
                    </label>

                    <input
                        type="number"
                        step="0.01"
                        name="limit"
                        value="<%= limit %>"
                        class="form-control"
                        required>

                </div>

                <button class="btn btn-primary">

                    Save Budget

                </button>

            </form>

        </div>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <h4 class="mb-3">
                Budget Summary
            </h4>

            <table class="table">

                <tr>
                    <th>Budget</th>
                    <td>₹ <%= limit.toFixed(2) %></td>
                </tr>

                <tr>
                    <th>Spent</th>
                    <td>₹ <%= spent.toFixed(2) %></td>
                </tr>

                <tr>
                    <th>Remaining</th>

                    <td class="<%= remaining >= 0 ? 'text-success' : 'text-danger' %>">

                        ₹ <%= remaining.toFixed(2) %>

                    </td>

                </tr>

            </table>

        </div>

    </div>

</div>

<%- include('../partials/footer') %>