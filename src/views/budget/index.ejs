<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container mt-5">

    <h2 class="mb-4">Monthly Budget</h2>

    <div class="card shadow mb-4">
        <div class="card-body">

            <form action="/budget" method="POST">

                <div class="mb-3">
                    <label class="form-label">Month</label>

                    <input
                        type="month"
                        class="form-control"
                        name="month"
                        value="<%= month %>"
                        required
                    >
                </div>

                <div class="mb-3">
                    <label class="form-label">Budget Amount (₹)</label>

                    <input
                        type="number"
                        class="form-control"
                        name="limit"
                        value="<%= limit || '' %>"
                        min="0"
                        required
                    >
                </div>

                <button class="btn btn-primary">
                    Save Budget
                </button>

            </form>

        </div>
    </div>

    <div class="card shadow">

        <div class="card-header">
            <h4>Budget Summary</h4>
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <tr>
                    <th>Month</th>
                    <td><%= month %></td>
                </tr>

                <tr>
                    <th>Budget</th>
                    <td>
                        <% if(limit !== null){ %>
                            ₹ <%= limit.toFixed(2) %>
                        <% } else { %>
                            Not Set
                        <% } %>
                    </td>
                </tr>

                <tr>
                    <th>Spent</th>
                    <td>₹ <%= spent.toFixed(2) %></td>
                </tr>

                <tr>
                    <th>Remaining</th>
                    <td>
                        <% if(remaining !== null){ %>
                            ₹ <%= remaining.toFixed(2) %>
                        <% } else { %>
                            Not Set
                        <% } %>
                    </td>
                </tr>

            </table>

        </div>

    </div>

</div>

<%- include('../partials/footer') %>