<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="shell">
  <div class="page-header">
    <h1>My Expenses</h1>
    <a href="/expenses/new" class="btn btn-primary">+ Add Expense</a>
  </div>

  <%- include('../partials/flash') %>

  <div class="card">
    <form class="filter-bar" method="GET" action="/expenses">
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">All categories</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c %>" <%= selectedCategory === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="month">Month</label>
        <input type="month" id="month" name="month" value="<%= selectedMonth %>" />
      </div>
      <button type="submit" class="btn btn-secondary">Filter</button>
      <a href="/expenses" class="btn btn-secondary">Clear</a>
    </form>
  </div>

  <div class="card">
    <% if (expenses.length === 0) { %>
      <div class="empty-state">
        <h3>No expenses found</h3>
        <p>Try clearing your filters or add a new expense.</p>
        <a href="/expenses/new" class="btn btn-primary" style="margin-top:12px;">+ Add Expense</a>
      </div>
    <% } else { %>
      <table class="ledger">
        <thead>
          <tr>
            <th>Date</th>
            <th>Title</th>
            <th>Category</th>
            <th>Notes</th>
            <th class="amount">Amount</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% expenses.forEach(function(e) { %>
            <tr>
              <td><%= e.date.toISOString().slice(0,10) %></td>
              <td><%= e.title %></td>
              <td><span class="tag"><%= e.category %></span></td>
              <td><%= e.notes || '-' %></td>
              <td class="amount">&#8377;<%= e.amount.toFixed(2) %></td>
              <td class="row-actions">
                <a href="/expenses/<%= e._id %>/edit">Edit</a>
                <form action="/expenses/<%= e._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this expense?');">
                  <button type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr class="ledger-total">
            <td colspan="4">Total</td>
            <td class="amount">&#8377;<%= total.toFixed(2) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>