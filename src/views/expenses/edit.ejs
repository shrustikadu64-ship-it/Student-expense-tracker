<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<div class="shell">
  <div class="page-header">
    <h1>Edit Expense</h1>
  </div>
  <%- include('../partials/flash') %>
  <div class="card" style="max-width:560px;">
    <form action="/expenses/<%= expense._id %>?_method=PUT" method="POST">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" value="<%= expense.title %>" required autofocus />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="amount">Amount (&#8377;)</label>
          <input type="number" id="amount" name="amount" min="0" step="0.01" value="<%= expense.amount %>" required />
        </div>
        <div class="form-group">
          <label for="date">Date</label>
          <input type="date" id="date" name="date" value="<%= expense.date.toISOString().slice(0,10) %>" required />
        </div>
      </div>
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          <% categories.forEach(function(c) { %>
            <option value="<%= c %>" <%= expense.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="notes">Notes (optional)</label>
        <textarea id="notes" name="notes" rows="3"><%= expense.notes %></textarea>
      </div>
      <div class="actions-row">
        <a href="/expenses" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Update Expense</button>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>